# LLM KnightTrader — copy to .env and fill in (never commit .env)

# Required: at least one OpenRouter key (free models used by default)
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional fallbacks
# GROQ_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Optional: path to Python 3.12+ for trader subprocess
# KNIGHTTRADER_PYTHON=C:\Python312\python.exe

# Optional: BloFin credentials file (default: credentials/blofin.txt)
# BLOFIN_CREDENTIALS_PATH=

# Dashboard
# KNIGHTTRADER_DASHBOARD_PORT=8765

# Trading
# KNIGHTTRADER_TARGET_EQUITY=1000000
# KNIGHTTRADER_LOOP_SEC=60
# KNIGHTTRADER_HARVEST_NTP_PCT=5.0
